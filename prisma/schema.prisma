generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  PENDING
  PAID
  CANCELLED
}

model Event {
  id            String   @id @default(uuid())
  title         String
  description   String
  location      String
  date          DateTime
  capacity      Int
  creatorId     String
  
  creator       User     @relation(fields: [creatorId], references: [id])
  tickets       Ticket[]

  createdAt     DateTime @default(now())
}

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  role      String    @default("USER")

  events    Event[]
  orders    Order[]

  createdAt DateTime  @default(now())
}

model Ticket {
  id        String    @id @default(uuid())
  eventId   String
  name      String
  price     Float
  quantity  Int

  event     Event     @relation(fields: [eventId], references: [id])
  orders    Order[]

  createdAt DateTime  @default(now())
}

model Order {
  id                String        @id @default(uuid())
 
  userId            String
  ticketId          String

  quantity          Int
  total             Float
  
  status            OrderStatus   @default(PENDING)
  paymentIntentId   String?       @unique
  
  user              User          @relation(fields: [userId], references: [id])
  ticket            Ticket        @relation(fields: [ticketId], references: [id])


  createdAt         DateTime      @default(now())

  @@index([userId])
  @@index([ticketId])
}